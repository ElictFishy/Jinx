<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="JinxApp.Views.GamePage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <!-- Dimensions de base (échelle 1.0). Elles sont recalculées
                 dynamiquement selon la taille de la fenêtre dans
                 GamePage.xaml.cs (OnSizeAllocated) pour rendre la page
                 responsive sur n'importe quelle taille d'écran PC. -->

            <!-- Barre du haut -->
            <x:Double x:Key="TopBarH">52</x:Double>
            <x:Double x:Key="LeaveW">100</x:Double>
            <x:Double x:Key="LeaveH">44</x:Double>
            <x:Double x:Key="TitleFont">26</x:Double>
            <x:Double x:Key="PillFont">15</x:Double>

            <!-- Plateau -->
            <x:Double x:Key="BoardCardW">90</x:Double>
            <x:Double x:Key="BoardCardH">126</x:Double>
            <x:Double x:Key="BoardSpacingH">14</x:Double>
            <x:Double x:Key="BoardSpacingV">14</x:Double>
            <x:Double x:Key="BoardValTop">13</x:Double>
            <x:Double x:Key="BoardValBig">38</x:Double>

            <!-- Barre du bas -->
            <x:Double x:Key="BottomBarH">150</x:Double>
            <x:Double x:Key="ChanceBtnW">80</x:Double>
            <x:Double x:Key="ChanceBtnH">105</x:Double>
            <x:Double x:Key="HandCardW">80</x:Double>
            <x:Double x:Key="HandCardH">114</x:Double>
            <x:Double x:Key="HandValTop">11</x:Double>
            <x:Double x:Key="HandValBig">32</x:Double>
            <x:Double x:Key="DiceBox">44</x:Double>
            <x:Double x:Key="DiceFont">26</x:Double>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <Image Source="background_clear.png" Aspect="AspectFill"/>
        <Grid RowDefinitions="Auto, *, Auto" Padding="14,12" RowSpacing="8">

            <!-- Ligne du haut : Quitter / Joueur courant / Score / Tour -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8" HeightRequest="{DynamicResource TopBarH}">
                <Button x:Name="LeaveBtn" Grid.Column="0" Text="Quitter" Clicked="OnLeaveClicked" HeightRequest="{DynamicResource LeaveH}" WidthRequest="{DynamicResource LeaveW}" VerticalOptions="Center"/>

                <Border Grid.Column="1" BackgroundColor="#80CCCCCC" StrokeShape="RoundRectangle 8" Padding="10,6" HorizontalOptions="Fill" VerticalOptions="Center">
                    <Label Text="{Binding CurrentPlayer.Name, StringFormat='Au tour de : {0}'}" FontFamily="Party Vibes" FontSize="{DynamicResource TitleFont}" TextColor="Black" HorizontalOptions="Center"/>
                </Border>

                <Border Grid.Column="2" BackgroundColor="#80CCCCCC" StrokeShape="RoundRectangle 8" Padding="10,6" VerticalOptions="Center">
                    <Label Text="{Binding CurrentPlayer.Score,StringFormat='{0} pts'}" FontFamily="OpenSansSemibold" FontSize="{DynamicResource PillFont}" TextColor="Black" HorizontalOptions="Center"/>
                </Border>

                <Border Grid.Column="3" BackgroundColor="#80CCCCCC" StrokeShape="RoundRectangle 8" Padding="10,6" VerticalOptions="Center">
                    <Label Text="{Binding CurrentRound,StringFormat='Tour {0}'}" FontFamily="OpenSansSemibold" FontSize="{DynamicResource PillFont}" TextColor="Black" HorizontalOptions="Center"/>
                </Border>
            </Grid>

            <!-- Plateau : remplit tout l'espace disponible (Row="1" avec *).
                 La taille des cartes est calculée pour que la grille 4x4 tienne
                 entièrement dans ce cadre (voir OnBoardSizeChanged). -->
            <Border x:Name="BoardFrame"
                    Grid.Row="1"
                    BackgroundColor="#80CCCCCC"
                    StrokeShape="RoundRectangle 16"
                    Padding="12,12"
                    HorizontalOptions="Fill"
                    VerticalOptions="Fill"
                    SizeChanged="OnBoardSizeChanged">

                <CollectionView x:Name="BoardView"
                                ItemsSource="{Binding Board.GridAsList}"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                VerticalScrollBarVisibility="Never"
                                SelectionMode="Single"
                                SelectionChanged="OnCardSelected">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical"
                                         Span="4"
                                         HorizontalItemSpacing="{DynamicResource BoardSpacingH}"
                                         VerticalItemSpacing="{DynamicResource BoardSpacingV}" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <!-- Cartes en format portrait, mises à l'échelle et centrées -->
                            <Grid WidthRequest="{DynamicResource BoardCardW}" HeightRequest="{DynamicResource BoardCardH}" HorizontalOptions="Center" VerticalOptions="Center">
                                <Border StrokeShape="RoundRectangle 12"
                                        Stroke="White"
                                        StrokeThickness="2"
                                        Padding="6,4"
                                        BackgroundColor="{Binding HexColor}"
                                        IsVisible="{Binding IsVisible}"
                                        WidthRequest="{DynamicResource BoardCardW}"
                                        HeightRequest="{DynamicResource BoardCardH}"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center">
                                    <Border.Shadow>
                                        <Shadow Brush="#000000" Offset="2,2" Radius="6" Opacity="0.25"/>
                                    </Border.Shadow>
                                    <Grid RowDefinitions="Auto,*,Auto">
                                        <Label Grid.Row="0" Text="{Binding DisplayValue}" FontSize="{DynamicResource BoardValTop}" FontAttributes="Bold" TextColor="White" HorizontalOptions="Start"/>
                                        <Label Grid.Row="1" Text="{Binding DisplayValue}" FontSize="{DynamicResource BoardValBig}" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                                        <Label Grid.Row="2" Text="{Binding DisplayValue}" FontSize="{DynamicResource BoardValTop}" FontAttributes="Bold" TextColor="White" HorizontalOptions="End" Rotation="180"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>

            <!-- Barre du bas : Cartes chance | Main joueur | Dé -->
            <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" HeightRequest="{DynamicResource BottomBarH}">

                <!-- Bouton "Cartes chance" — ouvre le panneau -->
                <Grid Grid.Column="0" WidthRequest="{DynamicResource ChanceBtnW}" HeightRequest="{DynamicResource ChanceBtnH}" VerticalOptions="Center">
                    <!-- Ombre -->
                    <Border BackgroundColor="#33000000" StrokeShape="RoundRectangle 14" StrokeThickness="0" TranslationX="3" TranslationY="3"/>
                    <!-- Carte cliquable -->
                    <Border x:Name="ChanceCardToggleBtn"
                            StrokeShape="RoundRectangle 14"
                            Stroke="White"
                            StrokeThickness="2"
                            WidthRequest="{DynamicResource ChanceBtnW}"
                            HeightRequest="{DynamicResource ChanceBtnH}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#9B59B6" Offset="0"/>
                                <GradientStop Color="#512BD4" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnChanceCardToggleTapped"/>
                        </Border.GestureRecognizers>
                        <Grid RowDefinitions="Auto,*,Auto" Padding="6,8">
                            <Label Grid.Row="0"
                                   Text="Cartes"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="9"
                                   TextColor="White"
                                   HorizontalOptions="Center"/>
                            <Label Grid.Row="1"
                                   Text="✦"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="28"
                                   TextColor="White"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                            <Label x:Name="ChanceCardCountLabel"
                                   Grid.Row="2"
                                   Text="0 carte(s)"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="8"
                                   TextColor="#DDB3FF"
                                   HorizontalOptions="Center"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Main du joueur (cartes numérotées) -->
                <Grid Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center" HeightRequest="{DynamicResource BottomBarH}">
                    <CollectionView x:Name="PlayerCard" ItemsSource="{Binding CurrentPlayer.NumberCards}"
                                    SelectionMode="Single"
                                    SelectionChanged="OnPlayerCardSelected">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid WidthRequest="{DynamicResource HandCardW}" HeightRequest="{DynamicResource HandCardH}" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Border StrokeShape="RoundRectangle 12"
                                            Stroke="White"
                                            StrokeThickness="2"
                                            Padding="6,4"
                                            BackgroundColor="{Binding HexColor}"
                                            WidthRequest="{DynamicResource HandCardW}"
                                            HeightRequest="{DynamicResource HandCardH}">
                                        <Border.Shadow>
                                            <Shadow Brush="#000000" Offset="2,2" Radius="3" Opacity="0.25"/>
                                        </Border.Shadow>
                                        <Grid RowDefinitions="Auto,*,Auto">
                                            <Label Grid.Row="0" Text="{Binding Value}" FontSize="{DynamicResource HandValTop}" FontAttributes="Bold" TextColor="White" HorizontalOptions="Start"/>
                                            <Label Grid.Row="1" Text="{Binding Value}" FontSize="{DynamicResource HandValBig}" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                                            <Label Grid.Row="2" Text="{Binding Value}" FontSize="{DynamicResource HandValTop}" FontAttributes="Bold" TextColor="White" HorizontalOptions="End" Rotation="180"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>

                <!-- Dé -->
                <Border Grid.Column="2" BackgroundColor="#80CCCCCC" StrokeShape="RoundRectangle 10" Padding="12,8" VerticalOptions="Center">
                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Border BackgroundColor="White" StrokeShape="RoundRectangle 8" Stroke="#2C3E50" StrokeThickness="2" WidthRequest="{DynamicResource DiceBox}" HeightRequest="{DynamicResource DiceBox}" HorizontalOptions="Center">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnDiceTapped"/>
                            </Border.GestureRecognizers>
                            <Label x:Name="LabelDiceValue"
                                   Text="?"
                                   FontSize="{DynamicResource DiceFont}"
                                   FontAttributes="Bold"
                                   TextColor="#2C3E50"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        <Label x:Name="LabelRollNumber"
                               Text="Appuyez pour lancer"
                               FontFamily="OpenSansSemibold"
                               FontSize="13"
                               TextColor="Black"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

            </Grid>
        </Grid>

        <!-- Bandeau IA -->
        <Border x:Name="AiBanner"
                IsVisible="False"
                BackgroundColor="#E6000000"
                StrokeShape="RoundRectangle 16"
                Stroke="#512BD4"
                StrokeThickness="2"
                Padding="24,18"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                MinimumWidthRequest="300">
            <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                <Label x:Name="AiTitleLabel"
                       Text="🤖 Tour de l'IA"
                       FontFamily="OpenSansSemibold"
                       FontSize="16"
                       TextColor="#9B59B6"
                       HorizontalOptions="Center"/>
                <Label x:Name="AiStatusLabel"
                       Text=""
                       FontFamily="OpenSansSemibold"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>
        </Border>

        <!-- Panneau Cartes chance (popup) -->
        <Border x:Name="ChanceCardPanel"
                IsVisible="False"
                BackgroundColor="#F0000000"
                StrokeShape="RoundRectangle 16"
                Stroke="#9B59B6"
                StrokeThickness="2"
                Padding="20,16"
                HorizontalOptions="Start"
                VerticalOptions="End"
                Margin="14,0,0,130"
                MinimumWidthRequest="200">
            <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="✦ Cartes chance"
                               FontFamily="OpenSansSemibold"
                               FontSize="13"
                               TextColor="#DDB3FF"/>
                        <Label Text="Chaque joueur peut piocher une carte chance en échange d'une carte numérotée"
                               FontFamily="OpenSansSemibold"
                               FontSize="9"
                               TextColor="#AA88CC"
                               LineBreakMode="WordWrap"
                               MaximumWidthRequest="260"/>
                    </VerticalStackLayout>
                    <Border Grid.Column="1"
                            BackgroundColor="#44FFFFFF"
                            StrokeShape="RoundRectangle 6"
                            StrokeThickness="0"
                            Padding="8,4">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnChanceCardPanelClose"/>
                        </Border.GestureRecognizers>
                        <Label Text="✕"
                               FontFamily="OpenSansSemibold"
                               FontSize="12"
                               TextColor="White"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                </Grid>

                <CollectionView x:Name="ChanceCardList"
                                ItemsSource="{Binding CurrentPlayer.ChanceCards}"
                                HeightRequest="110"
                                SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid WidthRequest="66" HeightRequest="94">
                                <!-- Ombre -->
                                <Border BackgroundColor="#33000000" StrokeShape="RoundRectangle 12" StrokeThickness="0" TranslationX="3" TranslationY="3"/>
                                <!-- Carte -->
                                <Border x:Name="ChanceCardBorder"
                                        StrokeShape="RoundRectangle 12"
                                        Stroke="White"
                                        StrokeThickness="2">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#9B59B6" Offset="0"/>
                                            <GradientStop Color="#512BD4" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            CommandParameter="{Binding .}"
                                            Tapped="OnChanceCardTapped"/>
                                    </Border.GestureRecognizers>
                                    <Grid RowDefinitions="Auto,*,Auto" Padding="5,4">
                                        <Label Grid.Row="0" Text="{Binding Type}" FontFamily="OpenSansSemibold" FontSize="7" TextColor="White" HorizontalOptions="Center" LineBreakMode="WordWrap"/>
                                        <Label Grid.Row="1" Text="✦" FontFamily="OpenSansSemibold" FontSize="26" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                                        <Label Grid.Row="2" Text="{Binding UsageLabel}" FontFamily="OpenSansSemibold" FontSize="7" TextColor="#DDB3FF" HorizontalOptions="Center"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    <CollectionView.EmptyView>
                        <Label Text="Aucune carte chance" FontSize="11" TextColor="#888" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </CollectionView.EmptyView>
                </CollectionView>

                <!-- Séparateur -->
                <BoxView HeightRequest="1" BackgroundColor="#44FFFFFF" Margin="0,4"/>

                <!-- Piocher une carte chance -->
                <Label Text="Piocher une carte chance"
                       FontFamily="OpenSansSemibold"
                       FontSize="11"
                       TextColor="#DDB3FF"
                       HorizontalOptions="Center"/>
                <Label Text="Choisissez une de vos cartes numérotées à échanger"
                       FontFamily="OpenSansSemibold"
                       FontSize="9"
                       TextColor="#AA88CC"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"/>
                <CollectionView x:Name="DrawChanceCardList"
                                ItemsSource="{Binding CurrentPlayer.NumberCards}"
                                HeightRequest="90"
                                SelectionMode="Single"
                                SelectionChanged="OnDrawChanceCardSelected">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid WidthRequest="60" HeightRequest="84" HorizontalOptions="Center" VerticalOptions="Center">
                                <Border StrokeShape="RoundRectangle 10"
                                        Stroke="White"
                                        StrokeThickness="1.5"
                                        Padding="4,3"
                                        BackgroundColor="{Binding HexColor}"
                                        WidthRequest="60"
                                        HeightRequest="84">
                                    <Border.Shadow>
                                        <Shadow Brush="#000000" Offset="2,2" Radius="3" Opacity="0.25"/>
                                    </Border.Shadow>
                                    <Grid RowDefinitions="Auto,*,Auto">
                                        <Label Grid.Row="0" Text="{Binding Value}" FontSize="9" FontAttributes="Bold" TextColor="White" HorizontalOptions="Start"/>
                                        <Label Grid.Row="1" Text="{Binding Value}" FontSize="24" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                                        <Label Grid.Row="2" Text="{Binding Value}" FontSize="9" FontAttributes="Bold" TextColor="White" HorizontalOptions="End" Rotation="180"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    <CollectionView.EmptyView>
                        <Label Text="Aucune carte en main" FontSize="11" TextColor="#888" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </CollectionView.EmptyView>
                </CollectionView>
            </VerticalStackLayout>
        </Border>

        <!-- Bandeau MULTI_COLOR : sélection de cartes en main -->
        <Border x:Name="MultiColorBanner"
                IsVisible="False"
                BackgroundColor="#F0000000"
                StrokeShape="RoundRectangle 16"
                Stroke="#9B59B6"
                StrokeThickness="2"
                Padding="20,16"
                HorizontalOptions="Center"
                VerticalOptions="End"
                Margin="0,0,0,30"
                MinimumWidthRequest="320">
            <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                <Label x:Name="MultiColorLabel"
                       Text="✦ MULTI COLOR — Sélectionnez des cartes de même couleur"
                       FontFamily="OpenSansSemibold"
                       FontSize="13"
                       TextColor="#DDB3FF"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"/>
                <CollectionView x:Name="MultiColorSelection"
                                SelectionMode="Multiple"
                                HeightRequest="114"
                                SelectionChanged="OnMultiColorSelectionChanged">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid WidthRequest="80" HeightRequest="104">
                                <Border StrokeShape="RoundRectangle 12"
                                        Stroke="White"
                                        StrokeThickness="2"
                                        Padding="6,4"
                                        BackgroundColor="{Binding HexColor}"
                                        WidthRequest="80"
                                        HeightRequest="104">
                                    <Grid RowDefinitions="Auto,*,Auto">
                                        <Label Grid.Row="0" Text="{Binding Value}" FontSize="11" FontAttributes="Bold" TextColor="White" HorizontalOptions="Start"/>
                                        <Label Grid.Row="1" Text="{Binding Value}" FontSize="30" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                                        <Label Grid.Row="2" Text="{Binding Value}" FontSize="11" FontAttributes="Bold" TextColor="White" HorizontalOptions="End" Rotation="180"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                <Label x:Name="MultiColorSumLabel"
                       Text="Somme : 0 / dé : ?"
                       FontFamily="OpenSansSemibold"
                       FontSize="12"
                       TextColor="White"
                       HorizontalOptions="Center"/>
                <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                    <Button Text="Confirmer" x:Name="MultiColorConfirmBtn"
                            Clicked="OnMultiColorConfirm"
                            BackgroundColor="#9B59B6"
                            TextColor="White"
                            FontFamily="OpenSansSemibold"
                            CornerRadius="8"
                            HeightRequest="38"/>
                    <Button Text="Annuler"
                            Clicked="OnMultiColorCancel"
                            BackgroundColor="#444"
                            TextColor="White"
                            FontFamily="OpenSansSemibold"
                            CornerRadius="8"
                            HeightRequest="38"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Border>

    </Grid>

</ContentPage>
